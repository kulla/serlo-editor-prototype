{
  "name": "rsbuild-react-bun-biome-starter-template",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.html --outdir dist/",
    "check": "bun run check:tsc && bun run check:format",
    "check:format": "biome check --write",
    "check:tsc": "tsc --noEmit",
    "dev": "bun --watch src/index.html",
    "format": "biome format --write",
    "preview": "bun run build && bun dist/index.html",
    "test:e2e": "./scripts/e2e-tests"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "es-toolkit": "1.46.1",
    "prosekit": "0.20.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "y-prosemirror": "1.3.7",
    "y-protocols": "1.0.7",
    "yjs": "13.6.30"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@playwright/test": "1.60.0",
    "@tsconfig/bun": "1.0.10",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  }
}
