{
  "name": "rsbuild-react-bun-biome-starter-template",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "check": "bun run check:tsc && bun run check:format",
    "check:format": "biome check --write",
    "check:tsc": "tsc --noEmit",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "es-toolkit": "1.45.1",
    "prosekit": "0.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "y-prosemirror": "1.3.7",
    "y-protocols": "1.0.7",
    "yjs": "13.6.30"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "1.59.1",
    "@rsbuild/core": "1.7.5",
    "@rsbuild/plugin-react": "1.4.6",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.13",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
